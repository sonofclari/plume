# Server
PORT=8080

# Scripts
RAG_URL=http://localhost:8080   # Base URL for the VaporRAG server (used by download scripts)

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag-documents
QDRANT_API_KEY=

# ─── Hugging Face (optional) ─────────────────────────────────────────────────
#
# Required only for gated models (Llama, Mistral, etc.).
# Qwen2.5 and nomic-embed-text-v1.5 are public — leave blank.
#
# HF_TOKEN=

# ─── Embeddings ──────────────────────────────────────────────────────────────
#
# Google Cloud VM (docker-compose.yml — vLLM):
#   EMBEDDER_URL=http://localhost:8001/v1
#   EMBEDDER_MODEL=nomic-ai/nomic-embed-text-v1.5
#
# Mac (docker-compose.mac.yml — Ollama running natively):
#   EMBEDDER_URL=http://localhost:11434/v1
#   EMBEDDER_MODEL=nomic-embed-text
#
EMBEDDER_URL=http://localhost:8001/v1
EMBEDDER_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=50
# EMBEDDER_KEY=          ← not needed for vLLM or Ollama; set for auth-protected endpoints

# ─── LLM (Chat Completions + Tool Calling) ───────────────────────────────────
#
# Google Cloud VM (docker-compose.yml — vLLM):
#   LLM_URL=http://localhost:8000/v1
#   LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#
# Mac (docker-compose.mac.yml — Ollama running natively):
#   LLM_URL=http://localhost:11434/v1
#   LLM_MODEL=gemma4:12b
#
# Model must support tool/function calling.
#
LLM_URL=http://localhost:8000/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_API_KEY=          ← same note as EMBEDDER_KEY above
